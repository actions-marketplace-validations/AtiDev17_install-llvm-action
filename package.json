{
  "name": "install-llvm-action",
  "version": "2.0.10",
  "description": "A GitHub Action for downloading and installing LLVM and Clang binaries.",
  "author": "Kyle Mayes <kyle@mayeses.com>",
  "license": "Apache-2.0",
  "main": "dist/main.js",
  "scripts": {
    "format": "prettier --write *.ts",
    "generate": "ts-node generate.ts",
    "build": "parcel build main.ts",
    "test": "ts-node test.ts test"
  },
  "dependencies": {
    "@actions/core": "^3.0.1",
    "@actions/exec": "^3.0.0",
    "@actions/io": "^3.0.2",
    "@actions/tool-cache": "^4.0.0"
  },
  "devDependencies": {
    "@octokit/rest": "^21",
    "@types/lodash": "^4",
    "@types/node": "~22",
    "json-stable-stringify": "^1",
    "lodash": "^4",
    "parcel": "^2",
    "ts-node": "^10",
    "typescript": "^5"
  },
  "targets": {
    "main": {
      "context": "node",
      "engines": { "node": "22" },
      "includeNodeModules": true
    }
  }
}
